import*.py

# cloudflare - never commit actual configurations
infrastructure/cloudflare/*-policy.json
infrastructure/cloudflare/*-policies.json
infrastructure/cloudflare/split-tunnel.json
!infrastructure/cloudflare/*.example.json
!infrastructure/cloudflare/README.md
